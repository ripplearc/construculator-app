<?xml version="1.0" encoding="UTF-8"?>
<mutations version="1.0">
    <!-- COST ESTIMATION LIST BLOC MUTATION TESTING -->
    <!-- Targets: BLoC for managing cost estimation list state -->

    <files>
        <file>lib/features/estimation/presentation/bloc/cost_estimation_list_bloc/cost_estimation_list_bloc.dart</file>
    </files>

    <exclude>
        <!-- Exclude logging (if any added later) -->
        <regex pattern="_logger\.(debug|info|warning|error)\s*\(" dotAll="false"/>

        <!-- Exclude super calls -->
        <regex pattern="super\." dotAll="false"/>
    </exclude>

    <rules>
        <!-- RULE 1: In _onStartWatching, skip emitting initial loading state -->
        <regex pattern="emit\(const CostEstimationListLoading\(\)\);" dotAll="true" id="bloc.state.skip_initial_loading">
            <mutation text="// emit(const CostEstimationListLoading());"/>
        </regex>

        <!-- RULE 2: In _onStartWatching, skip canceling previous subscription before re-subscribe -->
        <regex pattern="emit\(const CostEstimationListLoading\(\)\);\n\n    _streamSubscription\?\.cancel\(\);" dotAll="true" id="bloc.stream.skip_cancel_previous">
            <mutation text="emit(const CostEstimationListLoading());\n\n    // _streamSubscription?.cancel();"/>
        </regex>

        <!-- RULE 3: In _onStartWatching, skip null/empty project check -->
        <regex pattern="if \(projectId == null \|\| projectId\.isEmpty\) \{\n      _streamSubscription\?\.cancel\(\);" dotAll="true" id="bloc.state.skip_null_project_startwatching">
            <mutation text="if (false) {\n      _streamSubscription?.cancel();"/>
        </regex>

        <!-- RULE 5: In _onStartWatching listen callback, don't fetch hasMore from repository -->
        <regex pattern="\.listen\(\(result\) \{\n          final hasMore = _repository\.hasMoreEstimations\(projectId\);" dotAll="true" id="bloc.pagination.skip_hasmore_fetch">
            <mutation text=".listen((result) {\n          final hasMore = true;"/>
        </regex>

        <!-- RULE 8: In _onUpdated, skip preserving current estimations on error -->
        <regex pattern="final currentEstimations = state is CostEstimationListWithData" dotAll="true" id="bloc.error.skip_preserve_estimations">
            <mutation text="final currentEstimations = false"/>
        </regex>

        <!-- RULE 9: In _onUpdated, skip preserving current hasMore on error -->
        <regex pattern="final currentHasMore = state is CostEstimationListWithData" dotAll="true" id="bloc.error.skip_preserve_hasmore">
            <mutation text="final currentHasMore = false"/>
        </regex>

        <!-- RULE 10: In _onUpdated, emit loaded instead of empty when list is empty -->
        <regex pattern="if \(estimations\.isEmpty\) \{" dotAll="true" id="bloc.state.skip_empty_check">
            <mutation text="if (false) {"/>
        </regex>

        <!-- RULE 11: In _onLoadMore, skip type guard -->
        <regex pattern="if \(state is! CostEstimationListLoaded\) return;" dotAll="true" id="bloc.loadmore.skip_type_guard">
            <mutation text="// Skip type guard"/>
        </regex>

        <!-- RULE 12: In _onLoadMore, skip null/empty project check -->
        <regex pattern="if \(projectId == null \|\| projectId\.isEmpty\) \{\n      final currentState = state as CostEstimationListLoaded;" dotAll="true" id="bloc.loadmore.skip_null_project_check">
            <mutation text="if (false) {\n      final currentState = state as CostEstimationListLoaded;"/>
        </regex>

        <!-- RULE 13: In _onLoadMore, skip isLoadingMore guard -->
        <regex pattern="if \(currentState\.isLoadingMore \|\| !currentState\.hasMore\) return;" dotAll="true" id="bloc.loadmore.skip_guards">
            <mutation text="// Skip guards"/>
        </regex>

        <!-- RULE 14: In _onLoadMore, invert hasMore guard -->
        <regex pattern="\|\| !currentState\.hasMore" dotAll="true" id="bloc.loadmore.invert_hasmore">
            <mutation text="|| currentState.hasMore"/>
        </regex>

        <!-- RULE 15: In _onLoadMore, skip emitting isLoadingMore=true -->
        <regex pattern="emit\(currentState\.copyWith\(isLoadingMore: true\)\);" dotAll="true" id="bloc.state.skip_loading_true">
            <mutation text="// emit(currentState.copyWith(isLoadingMore: true));"/>
        </regex>

        <!-- RULE 16: In _onLoadMore fold callback, skip updating hasMore after load -->
        <regex pattern="\(estimations\) \{\n      final hasMore = _repository\.hasMoreEstimations\(projectId\);" dotAll="true" id="bloc.loadmore.skip_hasmore_update">
            <mutation text="(estimations) {\n      final hasMore = currentState.hasMore;"/>
        </regex>

        <!-- RULE 17: In _onLoadMore, skip emitting final state -->
        <regex pattern="emit\(currentState\.copyWith\(hasMore: hasMore, isLoadingMore: false\)\);" dotAll="true" id="bloc.state.skip_final_emit">
            <mutation text="// emit(currentState.copyWith(hasMore: hasMore, isLoadingMore: false));"/>
        </regex>

        <!-- RULE 18: In _onLoadMore, keep isLoadingMore=true after success -->
        <regex pattern="isLoadingMore: false" dotAll="true" id="bloc.state.wrong_loading_flag">
            <mutation text="isLoadingMore: true"/>
        </regex>

        <!-- RULE 19: In close, skip canceling stream subscription -->
        <regex pattern="_streamSubscription\?\.cancel\(\);\n    _projectChangeSubscription\?\.cancel\(\);" dotAll="true" id="bloc.cleanup.skip_cancel">
            <mutation text="// _streamSubscription?.cancel();\n    _projectChangeSubscription?.cancel();"/>
        </regex>

        <!-- RULE 20: In close, skip canceling project change subscription -->
        <regex pattern="_projectChangeSubscription\?\.cancel\(\);" dotAll="true" id="bloc.cleanup.skip_project_change_cancel">
            <mutation text="// _projectChangeSubscription?.cancel();"/>
        </regex>

        <!-- RULE 21: In _onStartWatching, skip ensuring project change listener -->
        <regex pattern="_ensureProjectChangeListener\(\);" dotAll="true" id="bloc.project.skip_ensure_listener">
            <mutation text="// _ensureProjectChangeListener();"/>
        </regex>

        <!-- RULE 22: In _ensureProjectChangeListener, skip null project unavailable event -->
        <regex pattern="add\(const _CostEstimationListProjectUnavailable\(\)\);" dotAll="true" id="bloc.project.skip_project_unavailable_event">
            <mutation text="// add(const _CostEstimationListProjectUnavailable());"/>
        </regex>

        <!-- RULE 23: In _ensureProjectChangeListener, skip re-watch when project changes -->
        <regex pattern="add\(const CostEstimationListStartWatching\(\)\);" dotAll="true" id="bloc.project.skip_restart_watch_on_change">
            <mutation text="// add(const CostEstimationListStartWatching());"/>
        </regex>

        <!-- RULE 24: In project unavailable error, use wrong failure type -->
        <regex pattern="failure: UnexpectedFailure\(\)," dotAll="true" id="bloc.project_unavailable.wrong_failure_type">
            <mutation text="failure: ServerFailure(),"/>
        </regex>
    </rules>

    <commands>
        <command group="cost_estimation_list_bloc" expected-return="0">flutter test test/features/estimations/units/blocs/cost_estimation_list_bloc_test.dart</command>
    </commands>

    <threshold failure="85">
        <rating over="85" name="A"/>
        <rating over="75" name="B"/>
        <rating over="65" name="C"/>
        <rating over="55" name="D"/>
        <rating over="35" name="E"/>
        <rating over="0" name="F"/>
    </threshold>
</mutations>
